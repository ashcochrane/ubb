DATABASE_URL=postgres://ubb:ubb@localhost:5433/ubb
REDIS_URL=redis://localhost:6380/1
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Sandbox (test-mode) Stripe — optional; required for sandbox tenants to call Stripe
# STRIPE_TEST_SECRET_KEY=sk_test_xxx
# STRIPE_TEST_WEBHOOK_SECRET=whsec_xxx
# STRIPE_CONNECT_TEST_CLIENT_ID=ca_xxx
UBB_PLATFORM_FEE_PERCENTAGE=1.0
UBB_ARREARS_DEFAULT_THRESHOLD=5000000
SECRET_KEY=change-me
DEBUG=True
UBB_TOPUP_SUCCESS_URL=http://localhost:3000/top-up/success
UBB_TOPUP_CANCEL_URL=http://localhost:3000/top-up/cancel
# Clerk — tenant-member token verification (identity build 1, #79). All unset =>
# member auth is OFF and the API is API-key-only. The Clerk session JWT must carry
# an `email` claim (a JWT-template custom claim) for first-login member matching.
# Production (RS256) — set the issuer and ONE key source (needs `cryptography`):
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Local/dev only (HS256 shared secret; never a real Clerk token, ignored if an
# RS256 key is set):
# CLERK_HS256_SECRET=a-local-dev-only-shared-secret-at-least-32-bytes
